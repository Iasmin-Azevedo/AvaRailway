PROJECT_NAME=AVA MJ Backend
API_V1_PREFIX=/api/v1
APP_ENV=development
APP_DEBUG=true

DATABASE_URL=sqlite:///./avamj.db
SECRET_KEY=troque-esta-chave-em-producao
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

MOODLE_URL=https://seu-moodle
MOODLE_TOKEN=seu-token
# Opcional: ao atribuir curso no AVA, inscrever o professor como aluno no Moodle (requer moodle_user_id no utilizador).
MOODLE_AUTO_ENROL_ON_ASSIGN=false
# ID do papel "aluno" no Moodle (confirme em Administração > Utilizadores > Permissões > Definir papéis).
MOODLE_STUDENT_ROLE_ID=5
# Relativo ao pacote app/ ou absoluto (ex.: /data/h5p no Railway)
H5P_CONTENT_DIR=templates/static/h5p
USER_UPLOAD_DIR=templates/static/uploads

ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
COOKIE_SECURE=false
COOKIE_DOMAIN=
ACCESS_COOKIE_NAME=access_token
REFRESH_COOKIE_NAME=refresh_token
RATE_LIMIT_DEFAULT=60/minute

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:0.5b
CHAT_USE_LANGCHAIN=true
OLLAMA_CONTEXT_LENGTH=256
OLLAMA_NUM_PREDICT=180
OLLAMA_CONNECT_TIMEOUT_SECONDS=10
OLLAMA_READ_TIMEOUT_SECONDS=45
CHAT_MAX_HISTORY_MESSAGES=10
CHAT_MAX_USER_MESSAGE_LENGTH=2000
CHAT_MEMORY_SUMMARY_EVERY=8
CHAT_RETRIEVAL_TOP_K=5
CHAT_ENABLE_SEMANTIC_SEARCH=false
CHAT_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHAT_SYSTEM_NAME=AVA MJ
CHAT_NLU_PROVIDER=local
WIT_AI_TOKEN=
WIT_AI_BASE_URL=https://api.wit.ai
WIT_AI_API_VERSION=20230416
